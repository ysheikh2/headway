cmd_cleanup() {
  load_env
  local target="${1:-}"
  local yes="false"

  # Allow --yes before or after the target
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes)
        yes="true"
        shift
        ;;
      data | images | kilo | claude | all)
        target="$1"
        shift
        ;;
      *)
        echo "Unknown cleanup arg: $1"
        echo "Usage: headway cleanup <data|images|kilo|claude|all> [--yes]"
        exit 1
        ;;
    esac
  done

  if [[ -z "$target" ]]; then
    echo "Usage: headway cleanup <data|images|kilo|claude|all> [--yes]"
    echo
    echo "  data    remove cached pricing and stats data (.data/)"
    echo "  images  remove pulled Docker images"
    echo "  kilo    remove Kilo client config"
    echo "  claude  remove Claude Code client config"
    echo "  all     all of the above"
    exit 1
  fi

  local do_data="false" do_images="false" do_kilo="false" do_claude="false"
  case "$target" in
    data) do_data="true" ;;
    images) do_images="true" ;;
    kilo) do_kilo="true" ;;
    claude) do_claude="true" ;;
    all)
      do_data="true"
      do_images="true"
      do_kilo="true"
      do_claude="true"
      ;;
  esac

  if [[ "$yes" != "true" ]]; then
    echo "This will remove:"
    [[ "$do_data" == "true" ]] && echo "  cached data (.data/)"
    [[ "$do_images" == "true" ]] && echo "  pulled Docker images"
    [[ "$do_kilo" == "true" ]] && echo "  Kilo client config"
    [[ "$do_claude" == "true" ]] && echo "  Claude Code client config"
    read -r -p "Proceed? (y/N): " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then
      echo "aborted"
      exit 0
    fi
  fi

  if [[ "$do_data" == "true" ]]; then
    rm -rf "$ROOT_DIR/.data"
    echo "removed .data/"
  fi
  if [[ "$do_images" == "true" ]]; then
    docker image rm "${HEADROOM_IMAGE:-$DEFAULT_HEADROOM_IMAGE}" 2>/dev/null || true
    docker image rm ghcr.io/berriai/litellm:main-stable 2>/dev/null || true
    echo "removed Docker images"
  fi
  if [[ "$do_kilo" == "true" ]]; then
    cleanup_kilo_config
    echo "removed Kilo config"
  fi
  if [[ "$do_claude" == "true" ]]; then
    cleanup_claude_config
    echo "removed Claude Code client config"
  fi
  echo "cleanup complete"
}

cmd_uninstall() {
  load_env
  local yes="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes)
        yes="true"
        shift
        ;;
      *)
        echo "Unknown uninstall arg: $1"
        exit 1
        ;;
    esac
  done

  if [[ "$yes" != "true" ]]; then
    echo "This will completely remove headway from your system:"
    echo "  - Stop and remove gateway containers"
    echo "  - Remove pulled Docker images and cached data"
    echo "  - Remove Kilo and Claude Code client configs"
    echo "  - Remove the ~/.local/bin/headway symlink"
    echo "  - Remove tab completion from your shell rc file"
    echo "  - Delete the headway directory ($ROOT_DIR)"
    echo
    read -r -p "Uninstall headway? (y/N): " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then
      echo "aborted"
      exit 0
    fi
  fi

  # Stop services and wipe all state
  if docker info >/dev/null 2>&1; then
    docker compose -f "$COMPOSE_FILE" down --remove-orphans 2>/dev/null || true
    docker rm -f headroom-gateway litellm-gateway headroom-bedrock-gateway 2>/dev/null || true
    docker image rm "${HEADROOM_IMAGE:-$DEFAULT_HEADROOM_IMAGE}" 2>/dev/null || true
    docker image rm ghcr.io/berriai/litellm:main-stable 2>/dev/null || true
    echo "stopped containers and removed images"
  fi
  rm -f "$ENV_FILE"
  rm -rf "$ROOT_DIR/.data"
  cleanup_kilo_config 2>/dev/null || true
  cleanup_claude_config 2>/dev/null || true
  echo "removed config and cached data"

  # Remove symlink
  local symlink="$HOME/.local/bin/headway"
  if [[ -L "$symlink" ]]; then
    rm -f "$symlink"
    echo "removed $symlink"
  fi

  # Strip completion lines from shell rc
  local shell_name
  shell_name="$(basename "${SHELL:-}")"
  local rc_file=""
  case "$shell_name" in
    zsh) rc_file="$HOME/.zshrc" ;;
    bash) rc_file="$HOME/.bashrc" ;;
  esac
  if [[ -n "$rc_file" && -f "$rc_file" ]] &&
    (grep -qF "# headway tab completion" "$rc_file" 2>/dev/null ||
      grep -qF "headway completion" "$rc_file" 2>/dev/null); then
    local tmp
    tmp="$(mktemp)"
    grep -v "headway tab completion\|headway completion" "$rc_file" >"$tmp" || true
    mv "$tmp" "$rc_file"
    echo "removed completion lines from $rc_file"
  fi
  # Fish: remove completion file
  local fish_target="$HOME/.config/fish/completions/headway.fish"
  if [[ -f "$fish_target" ]]; then
    rm -f "$fish_target"
    echo "removed $fish_target"
  fi

  # Delete repo dir last — bash keeps running in memory after the file is gone
  echo "removing $ROOT_DIR ..."
  rm -rf "$ROOT_DIR"
  echo "headway uninstalled"
}


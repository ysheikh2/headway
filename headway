cmd_auth() {
  require_cmd aws
  require_cmd python3
  require_docker

  load_env
  require_env
  sync_headroom_tuning_env

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local discovery_profile="${BEDROCK_DISCOVERY_AWS_PROFILE:-$bedrock_profile}"
  local aws_region="$AWS_REGION"

  ensure_aws_session "$aws_profile_name" "$aws_region"
  ensure_aws_session "$bedrock_profile" "$aws_region"
  ensure_aws_session "$discovery_profile" "$aws_region"

  # If litellm is already running and auth is in progress, don't kill it —
  # restarting mid-flow loses the device session and forces a new code.
  local litellm_state
  litellm_state=$(docker inspect litellm-gateway --format '{{.State.Status}}' 2>/dev/null || echo "absent")

  if [[ "$litellm_state" == "running" ]] && copilot_auth_pending; then
    echo "Copilot auth already in progress — waiting for it to complete..."
    wait_for_copilot_auth 600 || exit 1
  elif [[ "$litellm_state" != "running" ]] || copilot_auth_pending; then
    # litellm not running or token missing: start/restart litellm fresh
    docker rm -f litellm-gateway headroom-gateway 2>/dev/null || true
    docker compose -f "$COMPOSE_FILE" up -d litellm
    wait_for_copilot_auth 600 || exit 1
  elif copilot_token_expired_in_logs; then
    # Token file exists but litellm reports it as expired — wipe and re-auth.
    echo "Existing Copilot token has expired — re-authenticating..."
    copilot_clear_token
    docker compose -f "$COMPOSE_FILE" restart litellm 2>/dev/null || true
    sleep 5
    wait_for_copilot_auth 600 || exit 1
  fi

  # Wait for api-key.json then regenerate config so named copilot-* models load.
  wait_for_copilot_api_key
  generate_config "$aws_profile_name" "$discovery_profile"
  docker compose -f "$COMPOSE_FILE" restart litellm 2>/dev/null || true

  # Token is now present — bring headroom up (or restart it) cleanly.
  docker compose -f "$COMPOSE_FILE" up -d --remove-orphans

  # Also refresh bedrock lane.
  docker compose -f "$COMPOSE_FILE" up -d headroom-bedrock 2>/dev/null || true

  if ! wait_for_http "$GATEWAY_URL/livez" 30 2 >/dev/null; then
    echo "ERROR: gateway failed to become healthy after auth"
    echo "       Check logs: docker logs litellm-gateway"
    exit 1
  fi

  echo "auth refresh complete"
}

cmd_doctor() {
  require_cmd aws
  require_cmd curl
  require_cmd python3
  require_docker
  load_env
  require_env
  sync_headroom_tuning_env

  echo "=== headway doctor ==="
  echo

  echo "[containers]"
  docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' | grep -E 'headroom-gateway|litellm-gateway|headroom-bedrock-gateway' || true
  echo

  echo "[health]"
  local live bedrock
  live=$(curl -sf --max-time 5 "$GATEWAY_URL/livez" 2>/dev/null || true)
  bedrock=$(curl -sf --max-time 5 "$BEDROCK_URL/livez" 2>/dev/null || true)
  if [[ -n "$live" ]]; then
    echo "copilot lane healthy: yes"
  else
    echo "copilot lane healthy: no"
  fi
  if [[ -n "$bedrock" ]]; then
    echo "bedrock lane healthy: yes"
  else
    echo "bedrock lane healthy: no"
  fi
  echo

  echo "[models]"
  local models
  models=$(curl -sf --max-time 8 "$GATEWAY_URL/v1/models" 2>/dev/null || curl -sf --max-time 8 "$LITELLM_ADMIN_URL/v1/models" 2>/dev/null || true)
  if [[ -n "$models" ]]; then
    echo "$models" | python3 "$PY_HELPER" models-summary 2>/dev/null || echo "unable to parse model list"
  else
    echo "unable to fetch model list"
  fi
  echo

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local aws_region="$AWS_REGION"

  echo "[client config]"

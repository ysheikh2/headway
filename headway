cmd_config() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: headway config <regen|setup|show>"
    exit 1
  fi

  local sub="$1"
  shift
  case "$sub" in
    regen)
      require_cmd aws
      require_cmd python3
      load_env
      require_env
      sync_headroom_tuning_env
      local aws_profile_name="$AWS_PROFILE"
      local discovery_profile=""
      local region="$AWS_REGION"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --aws-profile)
            if [[ $# -lt 2 || "$2" == --* ]]; then
              echo "ERROR: --aws-profile requires value"
              exit 1
            fi
            aws_profile_name="$2"
            shift 2
            ;;
          --bedrock-discovery-aws-profile | --bedrock-discovery-profile)
            if [[ $# -lt 2 || "$2" == --* ]]; then
              echo "ERROR: --bedrock-discovery-aws-profile requires value"
              exit 1
            fi
            discovery_profile="$2"
            shift 2
            ;;
          *)
            echo "Unknown config regen arg: $1"
            exit 1
            ;;
        esac
      done
      if [[ -z "$discovery_profile" ]]; then
        discovery_profile="${BEDROCK_DISCOVERY_AWS_PROFILE:-${BEDROCK_AWS_PROFILE:-$aws_profile_name}}"
      fi

      ensure_aws_session "$discovery_profile" "$region"
      generate_config "$aws_profile_name" "$discovery_profile"
      ;;
    setup)
      local target="all"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          kilo | claude | all)
            target="$1"
            shift
            ;;
          *)
            echo "Unknown config setup arg: $1"
            exit 1
            ;;
        esac
      done

      load_env
      require_env
      local aws_profile_name="$AWS_PROFILE"
      local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
      local region="$AWS_REGION"

      if [[ "$target" == "all" || "$target" == "kilo" ]]; then
        setup_kilo_config
        echo "kilo config updated"
      fi
      if [[ "$target" == "all" || "$target" == "claude" ]]; then
        setup_claude_config "$bedrock_profile" "$region"
        echo "claude code config updated"
      fi
      ;;
    show)
      load_env
      echo "ENV file: $ENV_FILE"
      if [[ ! -f "$ENV_FILE" ]]; then
        echo "WARNING: .env file not found — values below are from shell environment"
      fi
      echo "AWS_PROFILE=${AWS_PROFILE:-<unset>}"
      echo "BEDROCK_AWS_PROFILE=${BEDROCK_AWS_PROFILE:-<unset>}"
      echo "BEDROCK_DISCOVERY_AWS_PROFILE=${BEDROCK_DISCOVERY_AWS_PROFILE:-<unset>}"
      echo "AWS_REGION=${AWS_REGION:-<unset>}"
      echo "HEADROOM_IMAGE=${HEADROOM_IMAGE:-<unset>}"
      echo "HEADROOM_COMPRESS_USER_MESSAGES=${HEADROOM_COMPRESS_USER_MESSAGES:-1}"
      echo "HEADROOM_MIN_TOKENS=${HEADROOM_MIN_TOKENS:-120}"
      echo "HEADROOM_PROTECT_RECENT=${HEADROOM_PROTECT_RECENT:-2}"
      echo "HEADWAY_BEDROCK_AUTO_CACHE_CONTROL=${HEADWAY_BEDROCK_AUTO_CACHE_CONTROL:-1}"
      echo "KILO_CONF=$KILO_CONF"
      echo "CLAUDE_CODE_SETTINGS=$CLAUDE_CODE_SETTINGS"
      ;;
    *)
      echo "Unknown config subcommand: $sub"
      exit 1
      ;;
  esac
}


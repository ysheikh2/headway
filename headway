#!/usr/bin/env bash
# headway - CLI for Headway (local AI gateway for Kilo, built on Headroom + LiteLLM).

set -euo pipefail

# Resolve symlink chain so ROOT_DIR points at the real repo, not an intermediate link.
_self="${BASH_SOURCE[0]}"
while [[ -L "$_self" ]]; do
  _link="$(readlink "$_self")"
  [[ "$_link" == /* ]] || _link="$(dirname "$_self")/$_link"
  _self="$_link"
  unset _link
done
ROOT_DIR="$(cd "$(dirname "$_self")" && pwd)"
unset _self
COMPOSE_FILE="$ROOT_DIR/docker-compose.yml"
# headway always manages both lanes; export COMPOSE_PROFILES so every
# docker compose invocation below includes the optional litellm service.
# Users running docker compose directly (without headway) get Bedrock-only
# by default; they can opt in with: docker compose --profile litellm up
export COMPOSE_PROFILES=litellm
ENV_FILE="$ROOT_DIR/.env"
KILO_CONF="$HOME/.config/kilo/kilo.jsonc"
case "$(uname -s 2>/dev/null)" in
  Darwin) CLAUDE_CODE_SETTINGS_DEFAULT="$HOME/Library/Application Support/Code/User/settings.json" ;;
  *) CLAUDE_CODE_SETTINGS_DEFAULT="$HOME/.config/Code/User/settings.json" ;;
esac
CLAUDE_CODE_SETTINGS="${CLAUDE_CODE_SETTINGS:-$CLAUDE_CODE_SETTINGS_DEFAULT}"
PY_HELPER="$ROOT_DIR/scripts/cli/headroom_python.py"

DEFAULT_AWS_REGION="eu-central-1"
DEFAULT_AWS_PROFILE="default"
DEFAULT_HEADROOM_IMAGE="ghcr.io/chopratejas/headroom:code"
ENV_TEMPLATE_FILE="$ROOT_DIR/.env.template"

GATEWAY_URL="http://127.0.0.1:4000"
BEDROCK_URL="http://127.0.0.1:4002"
LITELLM_ADMIN_URL="http://127.0.0.1:4001"

load_env() {
  # Unset all headway-managed vars so they can only come from .env, never
  # silently inherited from the outer shell environment.
  unset AWS_PROFILE AWS_REGION BEDROCK_AWS_PROFILE BEDROCK_DISCOVERY_AWS_PROFILE \
    HEADROOM_IMAGE HEADROOM_COMPRESS_USER_MESSAGES HEADROOM_MIN_TOKENS \
    HEADROOM_PROTECT_RECENT HEADWAY_BEDROCK_AUTO_CACHE_CONTROL \
    HEADWAY_BEDROCK_DEBUG_COMPRESS
  if [[ -f "$ENV_FILE" ]]; then
    set -o allexport
    # shellcheck source=/dev/null
    source "$ENV_FILE"
    set +o allexport
  fi
}

require_env() {
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "ERROR: .env not found at $ENV_FILE"
    echo "       Run 'headway init' to set up headway first"
    exit 1
  fi
  if [[ -z "${AWS_PROFILE:-}" ]]; then
    echo "ERROR: AWS_PROFILE is not set in $ENV_FILE"
    echo "       Run 'headway init' or pass --aws-profile"
    exit 1
  fi
  if [[ -z "${AWS_REGION:-}" ]]; then
    echo "ERROR: AWS_REGION is not set in $ENV_FILE"
    echo "       Run 'headway init' to configure"
    exit 1
  fi
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "ERROR: missing required command: $1"
    exit 1
  fi
}

require_docker() {
  if ! docker info >/dev/null 2>&1; then
    echo "ERROR: Docker is not running. Start Docker Desktop and retry."
    exit 1
  fi
}

iter_env_template_pairs() {
  if [[ -f "$ENV_TEMPLATE_FILE" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ -z "$line" ]] && continue
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      [[ "$line" != *"="* ]] && continue
      local key="${line%%=*}"
      local value="${line#*=}"
      [[ -z "$key" ]] && continue
      printf '%s=%s\n' "$key" "$value"
    done <"$ENV_TEMPLATE_FILE"
    return 0
  fi

  # Fallback defaults if template is missing.
  printf '%s\n' "AWS_PROFILE=$DEFAULT_AWS_PROFILE"
  printf '%s\n' "BEDROCK_AWS_PROFILE=$DEFAULT_AWS_PROFILE"
  printf '%s\n' "BEDROCK_DISCOVERY_AWS_PROFILE=$DEFAULT_AWS_PROFILE"
  printf '%s\n' "AWS_REGION=$DEFAULT_AWS_REGION"
  printf '%s\n' "HEADROOM_IMAGE=$DEFAULT_HEADROOM_IMAGE"
}

sync_headroom_tuning_env() {
  # Keep docker-compose behavior and local .env aligned for the copilot lane.
  # Defaults mirror upstream agent-friendly settings used by headroom wrap:
  # - compress user messages
  # - lower minimum token gate so medium tool payloads are compressible
  # - keep only the last 2 recent read outputs fully protected
  local k v
  local keys=(
    "HEADROOM_COMPRESS_USER_MESSAGES"
    "HEADROOM_MIN_TOKENS"
    "HEADROOM_PROTECT_RECENT"
    "HEADWAY_BEDROCK_AUTO_CACHE_CONTROL"
  )

  for k in "${keys[@]}"; do
    v=$(get_env_key "$k")
    if [[ -n "$v" ]]; then
      export "$k=$v"
    fi
  done
}

env_template_keys() {
  local pair
  while IFS= read -r pair; do
    echo "${pair%%=*}"
  done < <(iter_env_template_pairs)
}

env_template_default_for_key() {
  local target_key="$1"
  local pair
  while IFS= read -r pair; do
    local key="${pair%%=*}"
    local value="${pair#*=}"
    if [[ "$key" == "$target_key" ]]; then
      echo "$value"
      return 0
    fi
  done < <(iter_env_template_pairs)
  return 1
}

prompt_label_for_env_key() {
  local key="$1"
  case "$key" in
    AWS_PROFILE)
      echo "AWS profile (LiteLLM lane)"
      ;;
    BEDROCK_AWS_PROFILE)
      echo "Bedrock AWS profile"
      ;;
    BEDROCK_DISCOVERY_AWS_PROFILE)
      echo "Bedrock discovery profile"
      ;;
    AWS_REGION)
      echo "AWS region"
      ;;
    HEADROOM_IMAGE)
      echo "Headroom image (Python proxy + native bedrock binary)"
      ;;
    HEADROOM_COMPRESS_USER_MESSAGES)
      echo "Compress user messages (1=on, 0=off) — reduces tokens sent, default is fine"
      ;;
    HEADROOM_MIN_TOKENS)
      echo "Min tokens before compression kicks in — default is fine"
      ;;
    HEADROOM_PROTECT_RECENT)
      echo "Recent messages to keep uncompressed — default is fine"
      ;;
    HEADWAY_BEDROCK_AUTO_CACHE_CONTROL)
      echo "Auto cache-control for Bedrock (1=on) — default is fine"
      ;;
    *)
      echo "$key"
      ;;
  esac
}

ensure_env_defaults() {
  local aws_profile_override="${1:-}"

  [[ -f "$ENV_FILE" ]] || touch "$ENV_FILE"

  local pair key value
  while IFS= read -r pair; do
    key="${pair%%=*}"
    value="${pair#*=}"
    append_if_missing "$key" "$value"
  done < <(iter_env_template_pairs)

  if [[ -n "$aws_profile_override" ]]; then
    set_env_key "AWS_PROFILE" "$aws_profile_override"
    if [[ -n "$(get_env_key "BEDROCK_AWS_PROFILE")" ]]; then
      set_env_key "BEDROCK_AWS_PROFILE" "$aws_profile_override"
    fi
    if [[ -n "$(get_env_key "BEDROCK_DISCOVERY_AWS_PROFILE")" ]]; then
      set_env_key "BEDROCK_DISCOVERY_AWS_PROFILE" "$aws_profile_override"
    fi
  fi
}

append_if_missing() {
  local key="$1"
  local value="$2"
  if ! grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
    echo "${key}=${value}" >>"$ENV_FILE"
  fi
}

prompt_with_default() {
  local label="$1"
  local default_value="$2"
  local input=""

  read -r -p "$label [$default_value]: " input
  if [[ -z "$input" ]]; then
    echo "$default_value"
  else
    echo "$input"
  fi
}

prompt_required() {
  local label="$1"
  local input=""
  while [[ -z "$input" ]]; do
    read -r -p "$label (required): " input
    if [[ -z "$input" ]]; then
      echo "  This field is required — please enter a value." >&2
    fi
  done
  echo "$input"
}

run_init_questionnaire_if_needed() {
  local aws_profile_override="${1:-}"

  [[ -f "$ENV_FILE" ]] || touch "$ENV_FILE"

  if [[ -n "$aws_profile_override" ]]; then
    return 0
  fi

  local missing="false"
  local key
  while IFS= read -r key; do
    if [[ -z "$(get_env_key "$key")" ]]; then
      missing="true"
      break
    fi
  done < <(env_template_keys)

  if [[ "$missing" != "true" ]]; then
    return 0
  fi

  if [[ ! -t 0 ]]; then
    echo "Missing .env values detected; using defaults (non-interactive mode)."
    return 0
  fi

  echo "A few quick questions to set up your .env (press Enter to accept defaults — defaults are fine for most fields)."
  echo

  local aws_profile
  aws_profile="$(get_env_key "AWS_PROFILE")"
  # Use fd 3 for the key iterator so that read -r -p inside prompt_with_default
  # keeps reading from stdin (the terminal) rather than from the key stream.
  while IFS= read -r key <&3; do
    local current
    current="$(get_env_key "$key")"
    if [[ -n "$current" ]]; then
      continue
    fi

    local default_value
    default_value="$(env_template_default_for_key "$key" || true)"
    if [[ "$key" == "BEDROCK_AWS_PROFILE" || "$key" == "BEDROCK_DISCOVERY_AWS_PROFILE" ]]; then
      if [[ -n "$aws_profile" ]]; then
        default_value="$aws_profile"
      fi
    fi

    local label
    label="$(prompt_label_for_env_key "$key")"
    local answer
    if [[ "$key" == "AWS_PROFILE" ]]; then
      answer="$(prompt_required "$label")"
    else
      answer="$(prompt_with_default "$label" "$default_value")"
    fi
    set_env_key "$key" "$answer"

    if [[ "$key" == "AWS_PROFILE" ]]; then
      aws_profile="$answer"
    fi
  done 3< <(env_template_keys)
}

set_env_key() {
  local key="$1"
  local value="$2"
  python3 "$PY_HELPER" env-set "$ENV_FILE" "$key" "$value"
}

get_env_key() {
  local key="$1"
  python3 "$PY_HELPER" env-get "$ENV_FILE" "$key"
}

wait_for_http() {
  local url="$1"
  local attempts="${2:-30}"
  local delay="${3:-2}"
  local out=""
  local i
  for ((i = 1; i <= attempts; i++)); do
    out=$(curl -sf --max-time 4 "$url" 2>/dev/null || true)
    if [[ -n "$out" ]]; then
      echo "$out"
      return 0
    fi
    sleep "$delay"
  done
  return 1
}

ensure_aws_session() {
  local profile="$1"
  local region="$2"
  if ! AWS_REGION="$region" AWS_DEFAULT_REGION="$region" aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
    echo "AWS SSO expired for profile '$profile'. Launching login."
    aws sso login --profile "$profile"
  fi
}

compose_pull() {
  docker compose -f "$COMPOSE_FILE" pull litellm
  # headroom and headroom-bedrock share one image (HEADROOM_IMAGE). Only pull
  # from a registry — a locally-built override has no remote to fetch.
  local headroom_image
  headroom_image=$(docker compose -f "$COMPOSE_FILE" config --format json 2>/dev/null |
    python3 "$PY_HELPER" compose-image headroom 2>/dev/null || true)
  if [[ -n "$headroom_image" && "$headroom_image" == *"/"* ]]; then
    docker compose -f "$COMPOSE_FILE" pull headroom headroom-bedrock
  else
    echo "Skipping pull for local headroom image: ${headroom_image:-<unset>}"
  fi
}

setup_kilo_config() {
  mkdir -p "$(dirname "$KILO_CONF")"
  if [[ -f "$KILO_CONF" ]]; then
    cp "$KILO_CONF" "$KILO_CONF.bak-$(date +%Y%m%d-%H%M%S)"
  fi
  python3 "$PY_HELPER" kilo-setup "$KILO_CONF"
}

setup_claude_config() {
  local aws_profile="$1"
  local aws_region="$2"

  mkdir -p "$(dirname "$CLAUDE_CODE_SETTINGS")"
  if [[ -f "$CLAUDE_CODE_SETTINGS" ]]; then
    cp "$CLAUDE_CODE_SETTINGS" "$CLAUDE_CODE_SETTINGS.bak-$(date +%Y%m%d-%H%M%S)"
  fi
  python3 "$PY_HELPER" claude-setup "$CLAUDE_CODE_SETTINGS" "$aws_profile" "$aws_region"
}

cleanup_kilo_config() {
  if [[ ! -f "$KILO_CONF" ]]; then
    return 0
  fi
  python3 "$PY_HELPER" kilo-cleanup "$KILO_CONF"
}

cleanup_claude_config() {
  if [[ ! -f "$CLAUDE_CODE_SETTINGS" ]]; then
    return 0
  fi
  python3 "$PY_HELPER" claude-cleanup "$CLAUDE_CODE_SETTINGS"
}

generate_config() {
  local aws_profile="$1"
  local discovery_profile="$2"
  bash "$ROOT_DIR/scripts/cli/generate-litellm-config.sh" \
    --aws-profile "$aws_profile" \
    --bedrock-discovery-aws-profile "$discovery_profile" \
    --output "$ROOT_DIR/litellm_config.yaml"
}

sync_pricing() {
  local cache_dir="$ROOT_DIR/.data/headroom"
  local cache_file="$cache_dir/models-dev.json"
  local tmp_file="$cache_dir/models-dev.json.tmp.$$"
  mkdir -p "$cache_dir"

  if curl --silent --max-time 10 --fail \
    --output "$tmp_file" \
    "https://models.dev/api.json" 2>/dev/null &&
    python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$tmp_file" 2>/dev/null; then
    mv "$tmp_file" "$cache_file"
    echo "[pricing] cache updated from models.dev"
  else
    rm -f "$tmp_file" 2>/dev/null || true
    if [[ -f "$cache_file" ]]; then
      echo "[pricing] using cached pricing data"
    else
      echo "[pricing] no pricing cache available (network unavailable)"
    fi
  fi
}

copilot_token_file() {
  echo "$ROOT_DIR/.data/litellm/github_copilot/access-token"
}

copilot_auth_pending() {
  [[ ! -f "$(copilot_token_file)" ]]
}

# Return true if litellm logged "API key expired" since it last started.
# Used to detect a stale token that needs device re-auth even when the
# token file still exists on disk.
copilot_token_expired_in_logs() {
  local started_at
  started_at="$(docker inspect --format='{{.State.StartedAt}}' litellm-gateway 2>/dev/null || true)"
  docker logs --since "${started_at:-1970-01-01T00:00:00Z}" litellm-gateway 2>/dev/null |
    grep -q "API key expired" || return 1
}

# Wipe stale Copilot token files so the next wait_for_copilot_auth call
# treats the state as "auth needed" again.
copilot_clear_token() {
  local token_dir
  token_dir="$(dirname "$(copilot_token_file)")"
  rm -f "$token_dir/access-token" "$token_dir/api-key.json" 2>/dev/null || true
}

# After wait_for_copilot_auth completes (access-token written), LiteLLM may
# still be in the process of exchanging the OAuth token for an api-key.json.
# Wait up to 30 s for it to appear before calling generate_config — that file
# is what the Python generator reads to discover named copilot-* models.
wait_for_copilot_api_key() {
  local api_key_file
  api_key_file="$(dirname "$(copilot_token_file)")/api-key.json"
  local i
  for ((i = 0; i < 10; i++)); do
    [[ -f "$api_key_file" ]] && return 0
    sleep 3
  done
  return 0 # proceed even if the file never appeared
}

# After docker compose up, verify that Copilot models actually loaded into
# litellm.  If the model list has zero copilot-* entries, the token on disk
# may have expired beyond auto-refresh.  In that case, wipe the stale tokens,
# restart litellm so it can start a fresh device-auth flow, and hand off to
# wait_for_copilot_auth so the user sees the device code and completes auth.
ensure_copilot_healthy() {
  local aws_profile_name="$1"
  local discovery_profile="$2"

  # Give litellm a moment to finish loading its config.
  local i
  for ((i = 0; i < 10; i++)); do
    local count
    count=$(curl -sf --max-time 5 "$LITELLM_ADMIN_URL/v1/models" 2>/dev/null |
      python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
    print(sum(1 for m in d.get('data',[]) if m['id'].startswith('copilot-')))
except Exception:
    print(0)
" 2>/dev/null) || count=0
    if [[ "${count:-0}" -gt 0 ]]; then
      return 0 # Copilot models loaded — all good
    fi
    sleep 3
  done

  # Zero Copilot models after 30 s — token likely expired or never refreshed.
  if copilot_token_expired_in_logs; then
    echo
    echo "Copilot token expired — starting re-authentication..."
    copilot_clear_token
    docker compose -f "$COMPOSE_FILE" restart litellm 2>/dev/null || true
    sleep 5 # let litellm restart and issue a device code
    wait_for_copilot_auth 600 || return 1
    wait_for_copilot_api_key
    docker compose -f "$COMPOSE_FILE" restart headroom 2>/dev/null || true
    echo "Refreshing model config to include Copilot models..."
    generate_config "$aws_profile_name" "$discovery_profile"
    docker compose -f "$COMPOSE_FILE" restart litellm 2>/dev/null || true
    wait_for_http "$GATEWAY_URL/livez" 30 2 >/dev/null ||
      echo "WARNING: gateway did not become healthy after Copilot re-auth"
  else
    # No "expired" log — possibly no Copilot config (init ran before auth).
    # This is a silent no-op; the user can run 'headway auth' later.
    echo "NOTE: No Copilot models loaded. If you have a GitHub Copilot subscription,"
    echo "      run: headway auth"
  fi
}

# Read the most-recently-issued device code from litellm-gateway logs.
# Accepts an optional --since timestamp to exclude stale codes from prior
# sessions or restarts.
copilot_current_code() {
  local since="${1:-}"
  local docker_args=(litellm-gateway)
  [[ -n "$since" ]] && docker_args=(--since "$since" litellm-gateway)
  docker logs "${docker_args[@]}" 2>/dev/null |
    grep -oE 'code [A-Z0-9]{4}-[A-Z0-9]{4}' |
    tail -1 |
    awk '{print $2}' || true
}

# Poll until the Copilot token file appears or timeout (seconds, default 600).
# Streams the current device code to stdout each time it changes so users
# can enter whichever code is currently active.
wait_for_copilot_auth() {
  local timeout="${1:-600}"
  local elapsed=0
  local last_code=""
  local logs_since
  logs_since="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  if ! copilot_auth_pending; then
    return 0
  fi

  echo
  echo "Copilot device auth required. You have up to $((timeout / 60)) minutes."
  echo "  1. Visit   https://github.com/login/device"
  echo "  2. Enter   the code shown below (refreshes every ~60s if not used)"
  echo

  while [[ $elapsed -lt $timeout ]]; do
    if ! copilot_auth_pending; then
      echo "  Copilot auth complete."
      return 0
    fi

    # LiteLLM only makes 3 device-code attempts (~60s each) before giving up.
    # When exhausted, no new codes are issued and the token file is never written.
    # Use --since to check only logs after the last restart so stale entries
    # from a prior exhaustion don't trigger an immediate second restart.
    if docker logs --since "$logs_since" litellm-gateway 2>/dev/null |
      grep -q "Failed to get access token after 3 attempts"; then
      echo
      echo "  LiteLLM auth window expired — restarting to issue a fresh code..."
      docker compose -f "$COMPOSE_FILE" restart litellm 2>/dev/null || true
      logs_since="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      sleep 8
      last_code=""
      continue
    fi

    local code
    code=$(copilot_current_code "$logs_since")
    if [[ -n "$code" && "$code" != "$last_code" ]]; then
      echo "  Current code: $code  →  https://github.com/login/device"
      last_code="$code"
      # Copy code to clipboard (macOS / Linux X11 / Linux Wayland / WSL2).
      if command -v pbcopy >/dev/null 2>&1; then
        printf '%s' "$code" | pbcopy
        echo "  (code copied to clipboard)"
      elif command -v clip.exe >/dev/null 2>&1; then
        printf '%s' "$code" | clip.exe
        echo "  (code copied to clipboard)"
      elif command -v wl-copy >/dev/null 2>&1; then
        printf '%s' "$code" | wl-copy
        echo "  (code copied to clipboard)"
      elif command -v xclip >/dev/null 2>&1; then
        printf '%s' "$code" | xclip -selection clipboard
        echo "  (code copied to clipboard)"
      elif command -v xsel >/dev/null 2>&1; then
        printf '%s' "$code" | xsel --clipboard --input
        echo "  (code copied to clipboard)"
      fi
      # Open the auth page in the default browser.
      if command -v open >/dev/null 2>&1; then
        open "https://github.com/login/device" 2>/dev/null || true
      elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "https://github.com/login/device" 2>/dev/null || true
      elif command -v cmd.exe >/dev/null 2>&1; then
        cmd.exe /c start "https://github.com/login/device" 2>/dev/null || true
      fi
    fi
    sleep 5
    elapsed=$((elapsed + 5))
  done

  echo "ERROR: Copilot auth timed out after ${timeout}s."
  echo "       Re-run: headway auth"
  return 1
}

print_device_hint() {
  if ! copilot_auth_pending; then
    return 0
  fi
  local code
  code=$(copilot_current_code)
  if [[ -n "$code" ]]; then
    echo "Copilot device auth pending:"
    echo "  Please visit https://github.com/login/device and enter code $code to authenticate."
    echo "  Open: https://github.com/login/device"
  fi
}

check_copilot_auth_hint() {
  if ! copilot_auth_pending; then
    return 0
  fi
  local code
  code=$(copilot_current_code)
  if [[ -n "$code" ]]; then
    echo "WARNING: Copilot device auth is still pending. Complete it before running tests:"
    echo "  Please visit https://github.com/login/device and enter code $code to authenticate."
    echo "  Open: https://github.com/login/device"
    echo "  Then run: headway auth"
  fi
  return 1
}

cmd_init() {
  local aws_profile_override=""
  local skip_config="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --aws-profile)
        if [[ $# -lt 2 || "$2" == --* ]]; then
          echo "ERROR: --aws-profile requires value"
          exit 1
        fi
        aws_profile_override="$2"
        shift 2
        ;;
      --skip-config)
        skip_config="true"
        shift
        ;;
      *)
        echo "Unknown init arg: $1"
        exit 1
        ;;
    esac
  done

  require_cmd python3
  require_cmd aws
  require_docker

  echo
  echo "--- Step 1/3: Configure environment ---"
  echo
  load_env
  run_init_questionnaire_if_needed "$aws_profile_override"
  ensure_env_defaults "$aws_profile_override"
  load_env
  require_env

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local discovery_profile="${BEDROCK_DISCOVERY_AWS_PROFILE:-$bedrock_profile}"
  local aws_region="$AWS_REGION"

  echo
  echo "--- Step 2/3: Verify AWS access ---"
  echo
  ensure_aws_session "$aws_profile_name" "$aws_region"
  ensure_aws_session "$bedrock_profile" "$aws_region"
  ensure_aws_session "$discovery_profile" "$aws_region"

  echo
  echo "--- Step 3/3: Generate gateway configuration ---"
  echo

  setup_kilo_config
  setup_claude_config "$bedrock_profile" "$aws_region"

  if [[ "$skip_config" != "true" ]]; then
    echo "Discovering Bedrock models and generating gateway config..."
    echo "(Copilot models will be added automatically when you run 'headway up')"
    echo
    generate_config "$aws_profile_name" "$discovery_profile"
  fi

  setup_shell_completion

  echo
  echo "init complete"
  echo "- AWS_PROFILE: $aws_profile_name"
  echo "- BEDROCK_AWS_PROFILE: $bedrock_profile"
  echo "- BEDROCK_DISCOVERY_AWS_PROFILE: $discovery_profile"
  echo "- AWS_REGION: $aws_region"
  echo
  echo "Next: run 'headway up' to start the gateway and authenticate Copilot."
}

cmd_up() {
  local aws_profile_override=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --aws-profile)
        if [[ $# -lt 2 || "$2" == --* ]]; then
          echo "ERROR: --aws-profile requires value"
          exit 1
        fi
        aws_profile_override="$2"
        shift 2
        ;;
      *)
        echo "Unknown up arg: $1"
        exit 1
        ;;
    esac
  done

  require_cmd python3
  require_cmd aws
  require_docker

  load_env
  ensure_env_defaults "$aws_profile_override"
  load_env
  require_env
  sync_headroom_tuning_env

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local discovery_profile="${BEDROCK_DISCOVERY_AWS_PROFILE:-$bedrock_profile}"
  local aws_region="$AWS_REGION"

  ensure_aws_session "$aws_profile_name" "$aws_region"
  ensure_aws_session "$bedrock_profile" "$aws_region"
  ensure_aws_session "$discovery_profile" "$aws_region"

  sync_pricing

  echo
  echo "--- Starting gateway containers ---"
  echo
  docker compose -f "$COMPOSE_FILE" up -d --remove-orphans

  # Fresh install (no token): guide user through device auth interactively.
  if copilot_auth_pending; then
    echo
    echo "--- Authenticating GitHub Copilot ---"
    echo
    wait_for_copilot_auth 600 || exit 1
    wait_for_copilot_api_key
    # Restart headroom so it connects to litellm now that auth is done.
    docker compose -f "$COMPOSE_FILE" restart headroom 2>/dev/null || true
    # Regen config to add Copilot model entries that were skipped pre-auth.
    echo
    echo "--- Refreshing model config with Copilot models ---"
    echo
    generate_config "$aws_profile_name" "$discovery_profile"
    docker compose -f "$COMPOSE_FILE" restart litellm 2>/dev/null || true
  fi

  echo
  echo "--- Waiting for gateway to become healthy ---"
  echo
  if ! wait_for_http "$GATEWAY_URL/livez" 30 2 >/dev/null; then
    echo "ERROR: gateway did not become healthy at $GATEWAY_URL/livez"
    echo "       Check logs: docker logs litellm-gateway"
    exit 1
  fi
  if ! wait_for_http "$BEDROCK_URL/livez" 30 2 >/dev/null; then
    echo "ERROR: bedrock lane did not become healthy at $BEDROCK_URL/livez"
    exit 1
  fi

  # Token exists but may have expired (e.g. reinstall with old token file).
  # Detects expiry from litellm logs and auto-triggers re-auth if needed.
  if ! copilot_auth_pending; then
    ensure_copilot_healthy "$aws_profile_name" "$discovery_profile" || exit 1
  fi

  echo
  echo "gateway is up"
}


#!/usr/bin/env bash
# headway - CLI for Headway (local AI gateway for Kilo, built on Headroom + LiteLLM).

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="$ROOT_DIR/docker-compose.yml"
ENV_FILE="$ROOT_DIR/.env"
KILO_CONF="$HOME/.config/kilo/kilo.jsonc"
CLAUDE_CODE_SETTINGS_DEFAULT="$HOME/Library/Application Support/Code/User/settings.json"
CLAUDE_CODE_SETTINGS="${CLAUDE_CODE_SETTINGS:-$CLAUDE_CODE_SETTINGS_DEFAULT}"
PY_HELPER="$ROOT_DIR/scripts/cli/headroom_python.py"

DEFAULT_AWS_REGION="eu-central-1"
DEFAULT_AWS_PROFILE="default"
DEFAULT_BEDROCK_IMAGE="ghcr.io/ysheikh2/headway:bedrock-native"
ENV_TEMPLATE_FILE="$ROOT_DIR/.env.template"

GATEWAY_URL="http://127.0.0.1:4000"
BEDROCK_URL="http://127.0.0.1:4002"
LITELLM_ADMIN_URL="http://127.0.0.1:4001"

load_env() {
  # Unset all headway-managed vars so they can only come from .env, never
  # silently inherited from the outer shell environment.
  unset AWS_PROFILE AWS_REGION BEDROCK_AWS_PROFILE BEDROCK_DISCOVERY_AWS_PROFILE \
    HEADROOM_BEDROCK_IMAGE HEADROOM_COMPRESS_USER_MESSAGES HEADROOM_MIN_TOKENS \
    HEADROOM_PROTECT_RECENT HEADWAY_BEDROCK_AUTO_CACHE_CONTROL
  if [[ -f "$ENV_FILE" ]]; then
    set -o allexport
    # shellcheck source=/dev/null
    source "$ENV_FILE"
    set +o allexport
  fi
}

require_env() {
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "ERROR: .env not found at $ENV_FILE"
    echo "       Run 'headway init' to set up headway first"
    exit 1
  fi
  if [[ -z "${AWS_PROFILE:-}" ]]; then
    echo "ERROR: AWS_PROFILE is not set in $ENV_FILE"
    echo "       Run 'headway init' or pass --aws-profile"
    exit 1
  fi
  if [[ -z "${AWS_REGION:-}" ]]; then
    echo "ERROR: AWS_REGION is not set in $ENV_FILE"
    echo "       Run 'headway init' to configure"
    exit 1
  fi
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "ERROR: missing required command: $1"
    exit 1
  fi
}

require_docker() {
  if ! docker info >/dev/null 2>&1; then
    echo "ERROR: Docker is not running. Start Docker Desktop and retry."
    exit 1
  fi
}

iter_env_template_pairs() {
  if [[ -f "$ENV_TEMPLATE_FILE" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ -z "$line" ]] && continue
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      [[ "$line" != *"="* ]] && continue
      local key="${line%%=*}"
      local value="${line#*=}"
      [[ -z "$key" ]] && continue
      printf '%s=%s\n' "$key" "$value"
    done <"$ENV_TEMPLATE_FILE"
    return 0
  fi

  # Fallback defaults if template is missing.
  printf '%s\n' "AWS_PROFILE=$DEFAULT_AWS_PROFILE"
  printf '%s\n' "AWS_REGION=$DEFAULT_AWS_REGION"
  printf '%s\n' "HEADROOM_BEDROCK_IMAGE=$DEFAULT_BEDROCK_IMAGE"
}

sync_headroom_tuning_env() {
  # Keep docker-compose behavior and local .env aligned for the copilot lane.
  # Defaults mirror upstream agent-friendly settings used by headroom wrap:
  # - compress user messages
  # - lower minimum token gate so medium tool payloads are compressible
  # - keep only the last 2 recent read outputs fully protected
  local k v
  local keys=(
    "HEADROOM_COMPRESS_USER_MESSAGES"
    "HEADROOM_MIN_TOKENS"
    "HEADROOM_PROTECT_RECENT"
    "HEADWAY_BEDROCK_AUTO_CACHE_CONTROL"
  )

  for k in "${keys[@]}"; do
    v=$(get_env_key "$k")
    if [[ -n "$v" ]]; then
      export "$k=$v"
    fi
  done
}

env_template_keys() {
  local pair
  while IFS= read -r pair; do
    echo "${pair%%=*}"
  done < <(iter_env_template_pairs)
}

env_template_default_for_key() {
  local target_key="$1"
  local pair
  while IFS= read -r pair; do
    local key="${pair%%=*}"
    local value="${pair#*=}"
    if [[ "$key" == "$target_key" ]]; then
      echo "$value"
      return 0
    fi
  done < <(iter_env_template_pairs)
  return 1
}

prompt_label_for_env_key() {
  local key="$1"
  case "$key" in
    AWS_PROFILE)
      echo "AWS profile (LiteLLM lane)"
      ;;
    BEDROCK_AWS_PROFILE)
      echo "Bedrock AWS profile"
      ;;
    BEDROCK_DISCOVERY_AWS_PROFILE)
      echo "Bedrock discovery profile"
      ;;
    AWS_REGION)
      echo "AWS region"
      ;;
    HEADROOM_BEDROCK_IMAGE)
      echo "Bedrock lane image"
      ;;
    *)
      echo "$key"
      ;;
  esac
}

ensure_env_defaults() {
  local aws_profile_override="${1:-}"

  [[ -f "$ENV_FILE" ]] || touch "$ENV_FILE"

  local pair key value
  while IFS= read -r pair; do
    key="${pair%%=*}"
    value="${pair#*=}"
    append_if_missing "$key" "$value"
  done < <(iter_env_template_pairs)

  if [[ -n "$aws_profile_override" ]]; then
    set_env_key "AWS_PROFILE" "$aws_profile_override"
    if [[ -n "$(get_env_key "BEDROCK_AWS_PROFILE")" ]]; then
      set_env_key "BEDROCK_AWS_PROFILE" "$aws_profile_override"
    fi
    if [[ -n "$(get_env_key "BEDROCK_DISCOVERY_AWS_PROFILE")" ]]; then
      set_env_key "BEDROCK_DISCOVERY_AWS_PROFILE" "$aws_profile_override"
    fi
  fi

  # Migrate legacy local pinned image to rolling remote tag.
  local current_image
  current_image=$(get_env_key "HEADROOM_BEDROCK_IMAGE")
  if [[ "$current_image" == "headroom-local:bedrock-b08ec15-sso-esdefault" ]]; then
    set_env_key "HEADROOM_BEDROCK_IMAGE" "$DEFAULT_BEDROCK_IMAGE"
    echo "migrated HEADROOM_BEDROCK_IMAGE to $DEFAULT_BEDROCK_IMAGE"
  fi
}

append_if_missing() {
  local key="$1"
  local value="$2"
  if ! grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
    echo "${key}=${value}" >>"$ENV_FILE"
  fi
}

prompt_with_default() {
  local label="$1"
  local default_value="$2"
  local input=""

  read -r -p "$label [$default_value]: " input
  if [[ -z "$input" ]]; then
    echo "$default_value"
  else
    echo "$input"
  fi
}

run_init_questionnaire_if_needed() {
  local aws_profile_override="${1:-}"

  [[ -f "$ENV_FILE" ]] || touch "$ENV_FILE"

  if [[ -n "$aws_profile_override" ]]; then
    return 0
  fi

  local missing="false"
  local key
  while IFS= read -r key; do
    if [[ -z "$(get_env_key "$key")" ]]; then
      missing="true"
      break
    fi
  done < <(env_template_keys)

  if [[ "$missing" != "true" ]]; then
    return 0
  fi

  if [[ ! -t 0 ]]; then
    echo "Missing .env values detected; using defaults (non-interactive mode)."
    return 0
  fi

  echo "Missing .env values detected. Running quick setup prompts (press Enter to accept defaults)."

  local aws_profile="$(get_env_key "AWS_PROFILE")"
  while IFS= read -r key; do
    local current
    current="$(get_env_key "$key")"
    if [[ -n "$current" ]]; then
      continue
    fi

    local default_value
    default_value="$(env_template_default_for_key "$key" || true)"
    if [[ "$key" == "BEDROCK_AWS_PROFILE" || "$key" == "BEDROCK_DISCOVERY_AWS_PROFILE" ]]; then
      if [[ -n "$aws_profile" ]]; then
        default_value="$aws_profile"
      fi
    fi

    local label
    label="$(prompt_label_for_env_key "$key")"
    local answer
    answer="$(prompt_with_default "$label" "$default_value")"
    set_env_key "$key" "$answer"

    if [[ "$key" == "AWS_PROFILE" ]]; then
      aws_profile="$answer"
    fi
  done < <(env_template_keys)
}

set_env_key() {
  local key="$1"
  local value="$2"
  python3 "$PY_HELPER" env-set "$ENV_FILE" "$key" "$value"
}

get_env_key() {
  local key="$1"
  python3 "$PY_HELPER" env-get "$ENV_FILE" "$key"
}

wait_for_http() {
  local url="$1"
  local attempts="${2:-30}"
  local delay="${3:-2}"
  local out=""
  local i
  for ((i = 1; i <= attempts; i++)); do
    out=$(curl -sf --max-time 4 "$url" 2>/dev/null || true)
    if [[ -n "$out" ]]; then
      echo "$out"
      return 0
    fi
    sleep "$delay"
  done
  return 1
}

ensure_aws_session() {
  local profile="$1"
  local region="$2"
  if ! AWS_REGION="$region" AWS_DEFAULT_REGION="$region" aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
    echo "AWS SSO expired for profile '$profile'. Launching login."
    aws sso login --profile "$profile"
  fi
}

compose_pull() {
  docker compose -f "$COMPOSE_FILE" pull litellm headroom
  local bedrock_image
  bedrock_image=$(docker compose -f "$COMPOSE_FILE" config --format json 2>/dev/null |
    python3 "$PY_HELPER" compose-image headroom-bedrock 2>/dev/null || true)
  if [[ -n "$bedrock_image" && "$bedrock_image" == *"/"* ]]; then
    docker compose -f "$COMPOSE_FILE" pull headroom-bedrock
  else
    echo "Skipping pull for local headroom-bedrock image: ${bedrock_image:-<unset>}"
  fi
}

setup_kilo_config() {
  mkdir -p "$(dirname "$KILO_CONF")"
  if [[ -f "$KILO_CONF" ]]; then
    cp "$KILO_CONF" "$KILO_CONF.bak-$(date +%Y%m%d-%H%M%S)"
  fi
  python3 "$PY_HELPER" kilo-setup "$KILO_CONF"
}

setup_claude_config() {
  local aws_profile="$1"
  local aws_region="$2"

  mkdir -p "$(dirname "$CLAUDE_CODE_SETTINGS")"
  if [[ -f "$CLAUDE_CODE_SETTINGS" ]]; then
    cp "$CLAUDE_CODE_SETTINGS" "$CLAUDE_CODE_SETTINGS.bak-$(date +%Y%m%d-%H%M%S)"
  fi
  python3 "$PY_HELPER" claude-setup "$CLAUDE_CODE_SETTINGS" "$aws_profile" "$aws_region"
}

cleanup_kilo_config() {
  if [[ ! -f "$KILO_CONF" ]]; then
    return 0
  fi
  python3 "$PY_HELPER" kilo-cleanup "$KILO_CONF"
}

cleanup_claude_config() {
  if [[ ! -f "$CLAUDE_CODE_SETTINGS" ]]; then
    return 0
  fi
  python3 "$PY_HELPER" claude-cleanup "$CLAUDE_CODE_SETTINGS"
}

generate_config() {
  local aws_profile="$1"
  local discovery_profile="$2"
  bash "$ROOT_DIR/scripts/cli/generate-litellm-config.sh" \
    --aws-profile "$aws_profile" \
    --bedrock-discovery-aws-profile "$discovery_profile" \
    --output "$ROOT_DIR/litellm_config.yaml"
}

sync_pricing() {
  local cache_dir="$ROOT_DIR/.data/headroom"
  local cache_file="$cache_dir/models-dev.json"
  local tmp_file="$cache_dir/models-dev.json.tmp.$$"
  mkdir -p "$cache_dir"

  if curl --silent --max-time 10 --fail \
    --output "$tmp_file" \
    "https://models.dev/api.json" 2>/dev/null &&
    python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$tmp_file" 2>/dev/null; then
    mv "$tmp_file" "$cache_file"
    echo "[pricing] cache updated from models.dev"
  else
    rm -f "$tmp_file" 2>/dev/null || true
    if [[ -f "$cache_file" ]]; then
      echo "[pricing] using cached pricing data"
    else
      echo "[pricing] no pricing cache available (network unavailable)"
    fi
  fi
}

print_device_hint() {
  local code_line
  code_line=$(docker logs litellm-gateway 2>/dev/null | grep -E 'Please visit https://github.com/login/device and enter code' | tail -1 || true)
  if [[ -n "$code_line" ]]; then
    echo "Copilot device auth pending:"
    echo "  $code_line"
    echo "  Open: https://github.com/login/device"
  fi
}

check_copilot_auth_hint() {
  local code_line
  code_line=$(docker logs litellm-gateway 2>/dev/null | grep -E 'Please visit https://github.com/login/device and enter code' | tail -1 || true)
  if [[ -n "$code_line" ]]; then
    echo "WARNING: Copilot device auth is still pending. Complete it before running tests:"
    echo "  $code_line"
    echo "  Open: https://github.com/login/device"
    echo "  Then run: headway auth"
    return 1
  fi
  return 0
}

cmd_init() {
  local aws_profile_override=""
  local skip_config="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --aws-profile)
        if [[ $# -lt 2 || "$2" == --* ]]; then
          echo "ERROR: --aws-profile requires value"
          exit 1
        fi
        aws_profile_override="$2"
        shift 2
        ;;
      --skip-config)
        skip_config="true"
        shift
        ;;
      *)
        echo "Unknown init arg: $1"
        exit 1
        ;;
    esac
  done

  require_cmd python3
  require_cmd aws
  require_docker

  load_env
  run_init_questionnaire_if_needed "$aws_profile_override"
  ensure_env_defaults "$aws_profile_override"
  load_env
  require_env

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local discovery_profile="${BEDROCK_DISCOVERY_AWS_PROFILE:-$bedrock_profile}"
  local aws_region="$AWS_REGION"

  ensure_aws_session "$aws_profile_name" "$aws_region"
  ensure_aws_session "$bedrock_profile" "$aws_region"
  ensure_aws_session "$discovery_profile" "$aws_region"

  setup_kilo_config
  setup_claude_config "$bedrock_profile" "$aws_region"

  if [[ "$skip_config" != "true" ]]; then
    generate_config "$aws_profile_name" "$discovery_profile"
  fi

  setup_shell_completion

  echo "init complete"
  echo "- AWS_PROFILE: $aws_profile_name"
  echo "- BEDROCK_AWS_PROFILE: $bedrock_profile"
  echo "- BEDROCK_DISCOVERY_AWS_PROFILE: $discovery_profile"
  echo "- AWS_REGION: $aws_region"
}

cmd_up() {
  local aws_profile_override=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --aws-profile)
        if [[ $# -lt 2 || "$2" == --* ]]; then
          echo "ERROR: --aws-profile requires value"
          exit 1
        fi
        aws_profile_override="$2"
        shift 2
        ;;
      *)
        echo "Unknown up arg: $1"
        exit 1
        ;;
    esac
  done

  require_cmd python3
  require_cmd aws
  require_docker

  load_env
  ensure_env_defaults "$aws_profile_override"
  load_env
  require_env
  sync_headroom_tuning_env

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local aws_region="$AWS_REGION"

  ensure_aws_session "$aws_profile_name" "$aws_region"
  ensure_aws_session "$bedrock_profile" "$aws_region"

  docker compose -f "$COMPOSE_FILE" up -d --remove-orphans

  if ! wait_for_http "$GATEWAY_URL/livez" 30 2 >/dev/null; then
    echo "ERROR: gateway did not become healthy at $GATEWAY_URL/livez"
    exit 1
  fi
  if ! wait_for_http "$BEDROCK_URL/livez" 30 2 >/dev/null; then
    echo "ERROR: bedrock lane did not become healthy at $BEDROCK_URL/livez"
    exit 1
  fi

  print_device_hint
  echo "gateway is up"
}

cmd_update() {
  require_cmd aws
  require_cmd python3
  require_docker

  load_env
  require_env
  sync_headroom_tuning_env

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local discovery_profile="${BEDROCK_DISCOVERY_AWS_PROFILE:-$bedrock_profile}"
  local aws_region="$AWS_REGION"

  ensure_aws_session "$aws_profile_name" "$aws_region"
  ensure_aws_session "$bedrock_profile" "$aws_region"
  ensure_aws_session "$discovery_profile" "$aws_region"
  generate_config "$aws_profile_name" "$discovery_profile"

  sync_pricing
  compose_pull
  docker compose -f "$COMPOSE_FILE" up -d --remove-orphans

  wait_for_http "$GATEWAY_URL/livez" 20 2 >/dev/null || {
    echo "ERROR: gateway failed health check after update"
    exit 1
  }
  wait_for_http "$BEDROCK_URL/livez" 20 2 >/dev/null || {
    echo "ERROR: bedrock lane failed health check after update"
    exit 1
  }

  echo "update complete"
}

cmd_restart() {
  require_docker
  load_env
  require_env
  sync_headroom_tuning_env

  docker compose -f "$COMPOSE_FILE" down
  docker compose -f "$COMPOSE_FILE" up -d --remove-orphans

  if ! wait_for_http "$GATEWAY_URL/livez" 30 2 >/dev/null; then
    echo "ERROR: gateway did not become healthy at $GATEWAY_URL/livez"
    exit 1
  fi
  if ! wait_for_http "$BEDROCK_URL/livez" 30 2 >/dev/null; then
    echo "ERROR: bedrock lane did not become healthy at $BEDROCK_URL/livez"
    exit 1
  fi

  print_device_hint
  echo "restarted"
}

cmd_down() {
  require_docker
  docker compose -f "$COMPOSE_FILE" down
  echo "gateway is down"
}

cmd_auth() {
  require_cmd aws
  require_cmd python3
  require_docker

  load_env
  require_env
  sync_headroom_tuning_env

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local aws_region="$AWS_REGION"

  ensure_aws_session "$aws_profile_name" "$aws_region"
  ensure_aws_session "$bedrock_profile" "$aws_region"

  docker rm -f litellm-gateway headroom-gateway 2>/dev/null || true
  docker compose -f "$COMPOSE_FILE" up -d litellm headroom

  docker rm -f headroom-bedrock-gateway 2>/dev/null || true
  if ! docker compose -f "$COMPOSE_FILE" up -d headroom-bedrock; then
    echo "WARNING: bedrock lane failed to start; Copilot lane is still running"
  fi

  wait_for_http "$GATEWAY_URL/livez" 30 2 >/dev/null || {
    echo "ERROR: gateway failed to become healthy"
    print_device_hint
    exit 1
  }

  print_device_hint
  echo "auth refresh complete"
}

cmd_doctor() {
  require_cmd aws
  require_cmd curl
  require_cmd python3
  require_docker
  load_env
  require_env
  sync_headroom_tuning_env

  echo "=== headway doctor ==="
  echo

  echo "[containers]"
  docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' | grep -E 'headroom-gateway|litellm-gateway|headroom-bedrock-gateway' || true
  echo

  echo "[health]"
  local live bedrock
  live=$(curl -sf --max-time 5 "$GATEWAY_URL/livez" 2>/dev/null || true)
  bedrock=$(curl -sf --max-time 5 "$BEDROCK_URL/livez" 2>/dev/null || true)
  if [[ -n "$live" ]]; then
    echo "copilot lane healthy: yes"
  else
    echo "copilot lane healthy: no"
  fi
  if [[ -n "$bedrock" ]]; then
    echo "bedrock lane healthy: yes"
  else
    echo "bedrock lane healthy: no"
  fi
  echo

  echo "[models]"
  local models
  models=$(curl -sf --max-time 8 "$GATEWAY_URL/v1/models" 2>/dev/null || curl -sf --max-time 8 "$LITELLM_ADMIN_URL/v1/models" 2>/dev/null || true)
  if [[ -n "$models" ]]; then
    echo "$models" | python3 "$PY_HELPER" models-summary 2>/dev/null || echo "unable to parse model list"
  else
    echo "unable to fetch model list"
  fi
  echo

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local aws_region="$AWS_REGION"

  echo "[client config]"
  if [[ -f "$KILO_CONF" ]]; then
    if python3 "$PY_HELPER" kilo-check "$KILO_CONF" >/dev/null 2>&1; then
      echo "kilo: baseURL settings are aligned"
    else
      echo "kilo: baseURL settings mismatch; run: headway config setup kilo"
    fi
  else
    echo "kilo: missing $KILO_CONF; run: headway config setup kilo"
  fi
  if [[ -f "$CLAUDE_CODE_SETTINGS" ]]; then
    if python3 "$PY_HELPER" claude-check "$CLAUDE_CODE_SETTINGS" "$bedrock_profile" "$aws_region" >/dev/null 2>&1; then
      echo "claude code: bedrock env settings are aligned"
    else
      echo "claude code: settings mismatch; run: headway config setup claude"
    fi
  else
    echo "claude code: missing $CLAUDE_CODE_SETTINGS; run: headway config setup claude"
  fi
  echo

  echo "[compression tuning]"
  echo "HEADROOM_COMPRESS_USER_MESSAGES=${HEADROOM_COMPRESS_USER_MESSAGES:-1}"
  echo "HEADROOM_MIN_TOKENS=${HEADROOM_MIN_TOKENS:-120}"
  echo "HEADROOM_PROTECT_RECENT=${HEADROOM_PROTECT_RECENT:-2}"
  echo "HEADWAY_BEDROCK_AUTO_CACHE_CONTROL=${HEADWAY_BEDROCK_AUTO_CACHE_CONTROL:-1}"
  echo

  echo "[aws sessions]"
  if AWS_REGION="$aws_region" AWS_DEFAULT_REGION="$aws_region" aws sts get-caller-identity --profile "$aws_profile_name" >/dev/null 2>&1; then
    echo "AWS_PROFILE ($aws_profile_name): valid"
  else
    echo "AWS_PROFILE ($aws_profile_name): expired"
  fi
  if AWS_REGION="$aws_region" AWS_DEFAULT_REGION="$aws_region" aws sts get-caller-identity --profile "$bedrock_profile" >/dev/null 2>&1; then
    echo "BEDROCK_AWS_PROFILE ($bedrock_profile): valid"
  else
    echo "BEDROCK_AWS_PROFILE ($bedrock_profile): expired"
  fi
}

cmd_stats() {
  local raw_combined raw_stats raw_history
  raw_combined=$(python3 "$PY_HELPER" combined-stats 2>/dev/null || true)
  raw_stats=$(curl -sS --max-time 8 "$GATEWAY_URL/stats" 2>/dev/null || true)
  raw_history=$(curl -sS --max-time 8 "$GATEWAY_URL/stats-history" 2>/dev/null || true)

  if [[ -z "$raw_stats" ]]; then
    echo "ERROR: could not fetch stats from $GATEWAY_URL/stats"
    exit 1
  fi

  python3 "$PY_HELPER" stats-report "$raw_stats" "$raw_history" "$raw_combined"
}

cmd_config() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: headway config <regen|setup|show>"
    exit 1
  fi

  local sub="$1"
  shift
  case "$sub" in
    regen)
      require_cmd aws
      require_cmd python3
      load_env
      require_env
      sync_headroom_tuning_env
      local aws_profile_name="$AWS_PROFILE"
      local discovery_profile=""
      local region="$AWS_REGION"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --aws-profile)
            if [[ $# -lt 2 || "$2" == --* ]]; then
              echo "ERROR: --aws-profile requires value"
              exit 1
            fi
            aws_profile_name="$2"
            shift 2
            ;;
          --bedrock-discovery-aws-profile | --bedrock-discovery-profile)
            if [[ $# -lt 2 || "$2" == --* ]]; then
              echo "ERROR: --bedrock-discovery-aws-profile requires value"
              exit 1
            fi
            discovery_profile="$2"
            shift 2
            ;;
          *)
            echo "Unknown config regen arg: $1"
            exit 1
            ;;
        esac
      done
      if [[ -z "$discovery_profile" ]]; then
        discovery_profile="${BEDROCK_DISCOVERY_AWS_PROFILE:-${BEDROCK_AWS_PROFILE:-$aws_profile_name}}"
      fi

      ensure_aws_session "$discovery_profile" "$region"
      generate_config "$aws_profile_name" "$discovery_profile"
      ;;
    setup)
      local target="all"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          kilo | claude | all)
            target="$1"
            shift
            ;;
          *)
            echo "Unknown config setup arg: $1"
            exit 1
            ;;
        esac
      done

      load_env
      require_env
      local aws_profile_name="$AWS_PROFILE"
      local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
      local region="$AWS_REGION"

      if [[ "$target" == "all" || "$target" == "kilo" ]]; then
        setup_kilo_config
        echo "kilo config updated"
      fi
      if [[ "$target" == "all" || "$target" == "claude" ]]; then
        setup_claude_config "$bedrock_profile" "$region"
        echo "claude code config updated"
      fi
      ;;
    show)
      load_env
      echo "ENV file: $ENV_FILE"
      if [[ ! -f "$ENV_FILE" ]]; then
        echo "WARNING: .env file not found — values below are from shell environment"
      fi
      echo "AWS_PROFILE=${AWS_PROFILE:-<unset>}"
      echo "BEDROCK_AWS_PROFILE=${BEDROCK_AWS_PROFILE:-<unset>}"
      echo "BEDROCK_DISCOVERY_AWS_PROFILE=${BEDROCK_DISCOVERY_AWS_PROFILE:-<unset>}"
      echo "AWS_REGION=${AWS_REGION:-<unset>}"
      echo "HEADROOM_BEDROCK_IMAGE=${HEADROOM_BEDROCK_IMAGE:-<unset>}"
      echo "HEADROOM_COMPRESS_USER_MESSAGES=${HEADROOM_COMPRESS_USER_MESSAGES:-1}"
      echo "HEADROOM_MIN_TOKENS=${HEADROOM_MIN_TOKENS:-120}"
      echo "HEADROOM_PROTECT_RECENT=${HEADROOM_PROTECT_RECENT:-2}"
      echo "HEADWAY_BEDROCK_AUTO_CACHE_CONTROL=${HEADWAY_BEDROCK_AUTO_CACHE_CONTROL:-1}"
      echo "KILO_CONF=$KILO_CONF"
      echo "CLAUDE_CODE_SETTINGS=$CLAUDE_CODE_SETTINGS"
      ;;
    *)
      echo "Unknown config subcommand: $sub"
      exit 1
      ;;
  esac
}

cmd_reset() {
  local yes="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes)
        yes="true"
        shift
        ;;
      *)
        echo "Unknown reset arg: $1"
        exit 1
        ;;
    esac
  done

  if [[ "$yes" != "true" ]]; then
    echo "This will force-remove all gateway containers and restart the stack."
    echo "Your .env config is preserved. Use 'headway cleanup' to remove data or images."
    read -r -p "Proceed? (y/N): " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then
      echo "aborted"
      exit 0
    fi
  fi

  require_cmd python3
  require_cmd aws
  require_docker

  docker compose -f "$COMPOSE_FILE" down --remove-orphans 2>/dev/null || true
  docker rm -f headroom-gateway litellm-gateway headroom-bedrock-gateway 2>/dev/null || true

  load_env
  require_env
  sync_headroom_tuning_env

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local discovery_profile="${BEDROCK_DISCOVERY_AWS_PROFILE:-$bedrock_profile}"
  local aws_region="$AWS_REGION"

  ensure_aws_session "$aws_profile_name" "$aws_region"
  ensure_aws_session "$bedrock_profile" "$aws_region"
  ensure_aws_session "$discovery_profile" "$aws_region"
  generate_config "$aws_profile_name" "$discovery_profile"

  sync_pricing
  compose_pull
  docker compose -f "$COMPOSE_FILE" up -d --remove-orphans

  if ! wait_for_http "$GATEWAY_URL/livez" 30 2 >/dev/null; then
    echo "ERROR: gateway did not become healthy at $GATEWAY_URL/livez"
    exit 1
  fi
  if ! wait_for_http "$BEDROCK_URL/livez" 30 2 >/dev/null; then
    echo "ERROR: bedrock lane did not become healthy at $BEDROCK_URL/livez"
    exit 1
  fi

  print_device_hint
  echo "reset complete — gateway is back up"
}

cmd_cleanup() {
  local target="${1:-}"
  local yes="false"

  # Allow --yes before or after the target
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes)
        yes="true"
        shift
        ;;
      data | images | kilo | claude | all)
        target="$1"
        shift
        ;;
      *)
        echo "Unknown cleanup arg: $1"
        echo "Usage: headway cleanup <data|images|kilo|claude|all> [--yes]"
        exit 1
        ;;
    esac
  done

  if [[ -z "$target" ]]; then
    echo "Usage: headway cleanup <data|images|kilo|claude|all> [--yes]"
    echo
    echo "  data    remove cached pricing and stats data (.data/)"
    echo "  images  remove pulled Docker images"
    echo "  kilo    remove Kilo client config"
    echo "  claude  remove Claude Code client config"
    echo "  all     all of the above"
    exit 1
  fi

  local do_data="false" do_images="false" do_kilo="false" do_claude="false"
  case "$target" in
    data) do_data="true" ;;
    images) do_images="true" ;;
    kilo) do_kilo="true" ;;
    claude) do_claude="true" ;;
    all)
      do_data="true"
      do_images="true"
      do_kilo="true"
      do_claude="true"
      ;;
  esac

  if [[ "$yes" != "true" ]]; then
    echo "This will remove:"
    [[ "$do_data" == "true" ]] && echo "  cached data (.data/)"
    [[ "$do_images" == "true" ]] && echo "  pulled Docker images"
    [[ "$do_kilo" == "true" ]] && echo "  Kilo client config"
    [[ "$do_claude" == "true" ]] && echo "  Claude Code client config"
    read -r -p "Proceed? (y/N): " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then
      echo "aborted"
      exit 0
    fi
  fi

  if [[ "$do_data" == "true" ]]; then
    rm -rf "$ROOT_DIR/.data"
    echo "removed .data/"
  fi
  if [[ "$do_images" == "true" ]]; then
    docker image rm ghcr.io/chopratejas/headroom:code 2>/dev/null || true
    docker image rm ghcr.io/berriai/litellm:main-stable 2>/dev/null || true
    docker image rm ghcr.io/ysheikh2/headway:bedrock-native 2>/dev/null || true
    docker image rm ghcr.io/ysheikh2/headway:bedrock-native-latest 2>/dev/null || true
    echo "removed Docker images"
  fi
  if [[ "$do_kilo" == "true" ]]; then
    cleanup_kilo_config
    echo "removed Kilo config"
  fi
  if [[ "$do_claude" == "true" ]]; then
    cleanup_claude_config
    echo "removed Claude Code client config"
  fi
  echo "cleanup complete"
}

cmd_uninstall() {
  local yes="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes)
        yes="true"
        shift
        ;;
      *)
        echo "Unknown uninstall arg: $1"
        exit 1
        ;;
    esac
  done

  if [[ "$yes" != "true" ]]; then
    echo "This will completely remove headway from your system:"
    echo "  - Stop and remove gateway containers"
    echo "  - Remove pulled Docker images and cached data"
    echo "  - Remove Kilo and Claude Code client configs"
    echo "  - Remove the ~/.local/bin/headway symlink"
    echo "  - Remove tab completion from your shell rc file"
    echo "  - Delete the headway directory ($ROOT_DIR)"
    echo
    read -r -p "Uninstall headway? (y/N): " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then
      echo "aborted"
      exit 0
    fi
  fi

  # Stop services and wipe all state
  if docker info >/dev/null 2>&1; then
    docker compose -f "$COMPOSE_FILE" down --remove-orphans 2>/dev/null || true
    docker rm -f headroom-gateway litellm-gateway headroom-bedrock-gateway 2>/dev/null || true
    docker image rm ghcr.io/chopratejas/headroom:code 2>/dev/null || true
    docker image rm ghcr.io/berriai/litellm:main-stable 2>/dev/null || true
    docker image rm ghcr.io/ysheikh2/headway:bedrock-native 2>/dev/null || true
    docker image rm ghcr.io/ysheikh2/headway:bedrock-native-latest 2>/dev/null || true
    echo "stopped containers and removed images"
  fi
  rm -f "$ENV_FILE"
  rm -rf "$ROOT_DIR/.data"
  cleanup_kilo_config 2>/dev/null || true
  cleanup_claude_config 2>/dev/null || true
  echo "removed config and cached data"

  # Remove symlink
  local symlink="$HOME/.local/bin/headway"
  if [[ -L "$symlink" ]]; then
    rm -f "$symlink"
    echo "removed $symlink"
  fi

  # Strip completion lines from shell rc
  local shell_name
  shell_name="$(basename "${SHELL:-}")"
  local rc_file=""
  case "$shell_name" in
    zsh) rc_file="$HOME/.zshrc" ;;
    bash) rc_file="$HOME/.bashrc" ;;
  esac
  if [[ -n "$rc_file" && -f "$rc_file" ]] && grep -qF "headway completion" "$rc_file" 2>/dev/null; then
    local tmp
    tmp="$(mktemp)"
    grep -vF "headway completion" "$rc_file" >"$tmp" || true
    mv "$tmp" "$rc_file"
    echo "removed completion lines from $rc_file"
  fi
  # Fish: remove completion file
  local fish_target="$HOME/.config/fish/completions/headway.fish"
  if [[ -f "$fish_target" ]]; then
    rm -f "$fish_target"
    echo "removed $fish_target"
  fi

  # Delete repo dir last — bash keeps running in memory after the file is gone
  echo "removing $ROOT_DIR ..."
  rm -rf "$ROOT_DIR"
  echo "headway uninstalled"
}

cmd_test() {
  require_cmd aws
  require_cmd python3
  require_docker

  load_env
  require_env

  local aws_profile_name="$AWS_PROFILE"
  local bedrock_profile="${BEDROCK_AWS_PROFILE:-$aws_profile_name}"
  local aws_region="$AWS_REGION"

  if ! AWS_REGION="$aws_region" AWS_DEFAULT_REGION="$aws_region" \
    aws sts get-caller-identity --profile "$bedrock_profile" >/dev/null 2>&1; then
    echo "ERROR: AWS credentials expired for profile '$bedrock_profile'."
    echo "       Fix: headway auth"
    exit 1
  fi

  check_copilot_auth_hint || true

  exec bash "$ROOT_DIR/scripts/cli/test.sh" "$@"
}


}

setup_shell_completion() {
  local shell_name
  shell_name="$(basename "${SHELL:-}")"

  local rc_file eval_line

  case "$shell_name" in
    zsh)
      rc_file="$HOME/.zshrc"
      eval_line="eval \"\$(\"$ROOT_DIR/headway\" completion zsh)\"  # headway tab completion"
      ;;
    bash)
      rc_file="$HOME/.bashrc"
      eval_line="eval \"\$(\"$ROOT_DIR/headway\" completion bash)\"  # headway tab completion"
      ;;
    fish)
      local fish_completions_dir="$HOME/.config/fish/completions"
      local fish_target="$fish_completions_dir/headway.fish"
      if [[ -f "$fish_target" ]]; then
        echo "- completion: fish completions already installed at $fish_target (skipped)"
        return 0
      fi
      if [[ ! -t 0 ]]; then
        return 0
      fi
      read -r -p "Install fish tab completions to $fish_target? (y/N): " ans
      if [[ "$ans" =~ ^[Yy]$ ]]; then
        mkdir -p "$fish_completions_dir"
        bash "$ROOT_DIR/headway" completion fish >"$fish_target"
        echo "- completion: fish completions installed — restart your shell"
      else
        echo "- completion: skipped (run 'headway completion fish > $fish_target' later)"
      fi
      return 0
      ;;
    *)
      echo "- completion: unsupported shell '$shell_name' — run 'headway completion bash|zsh|fish' manually"
      return 0
      ;;
  esac

  # Idempotency: skip if the eval line (or anything referencing headway completion) is already present.
  if grep -qF "headway completion" "$rc_file" 2>/dev/null; then
    echo "- completion: already configured in $rc_file (skipped)"
    return 0
  fi

  if [[ ! -t 0 ]]; then
    return 0
  fi

  read -r -p "Add tab completion to $rc_file? (y/N): " ans
  if [[ "$ans" =~ ^[Yy]$ ]]; then
    printf '\n%s\n' "$eval_line" >>"$rc_file"
    echo "- completion: added to $rc_file — run 'source $rc_file' or open a new shell"
  else
    echo "- completion: skipped (add manually: $eval_line)"
  fi
}

cmd_completion() {
  local shell="${1:-}"
  if [[ -z "$shell" || "$shell" == "auto" ]]; then
    shell="$(basename "${SHELL:-bash}")"
    # fish can't use eval "$(cmd)" — it needs the file written directly
    if [[ "$shell" == "fish" ]]; then
      echo "# fish detected — write this to ~/.config/fish/completions/headway.fish" >&2
    fi
  fi
  local completion_script="$ROOT_DIR/scripts/cli/headway-completion.bash"

  case "$shell" in
    bash)
      cat "$completion_script"
      ;;
    zsh)
      cat <<'ZSHEOF'
# headway zsh completion — wraps the bash completion via bashcompinit.
autoload -Uz bashcompinit 2>/dev/null && bashcompinit 2>/dev/null
ZSHEOF
      cat "$completion_script"
      ;;
    fish)
      cat <<'FISHEOF'
# headway fish completion

set -l _hw_cmds up down restart reset auth init config doctor stats test cleanup uninstall secret-scan completion help

complete -c headway -f -n '__fish_use_subcommand' -a "$_hw_cmds"

# up
complete -c headway -n '__fish_seen_subcommand_from up' -l aws-profile -d 'AWS profile name'

# init
complete -c headway -n '__fish_seen_subcommand_from init' -l aws-profile -d 'AWS profile name'
complete -c headway -n '__fish_seen_subcommand_from init' -l skip-config -d 'Skip Kilo/Claude config generation'

# config subcommands
complete -c headway -n '__fish_seen_subcommand_from config' -a 'show regen setup'
complete -c headway -n '__fish_seen_subcommand_from config; and __fish_seen_subcommand_from regen' -l aws-profile -d 'AWS profile name'
complete -c headway -n '__fish_seen_subcommand_from config; and __fish_seen_subcommand_from regen' -l bedrock-discovery-aws-profile -d 'Bedrock discovery profile'
complete -c headway -n '__fish_seen_subcommand_from config; and __fish_seen_subcommand_from setup' -a 'kilo claude all'

# cleanup
complete -c headway -n '__fish_seen_subcommand_from cleanup' -a 'data images kilo claude all'
complete -c headway -n '__fish_seen_subcommand_from cleanup' -l yes -d 'Skip confirmation prompt'

# reset / uninstall
complete -c headway -n '__fish_seen_subcommand_from reset' -l yes -d 'Skip confirmation prompt'
complete -c headway -n '__fish_seen_subcommand_from uninstall' -l yes -d 'Skip confirmation prompt'

# completion
complete -c headway -n '__fish_seen_subcommand_from completion' -a 'bash zsh fish auto'
FISHEOF
      ;;
    *)
      echo "Unknown shell: $shell. Supported: bash, zsh, fish" >&2
      exit 1
      ;;
  esac
}

print_help() {
  cat <<'EOF'
Usage: headway <command> [options]

LIFECYCLE
  up [--aws-profile <name>]
      Start the stack with current config — no image pull, no config regen

  down
      Stop the gateway stack

  update
      Regenerate litellm config, pull latest images, restart

  restart
      Quick stop and start, no image pull, no config regen

  reset [--yes]
      Hard restart: force-remove containers, regen config, pull images, start fresh
      (.env is preserved — use 'headway cleanup' to remove data or images separately)

  auth
      Refresh AWS sessions and restart services

SETUP & CONFIGURATION
  init [--aws-profile <name>] [--skip-config]
      First-time setup: .env, AWS preflight, Kilo + Claude Code config,
      model config generation, and shell tab completion

  config show
      Show active environment settings

  config regen [--aws-profile <name>] [--bedrock-discovery-aws-profile <name>]
      Regenerate litellm_config.yaml

  config setup [kilo|claude|all]
      Write client configs (default: all)

DIAGNOSTICS
  doctor
      Health and configuration diagnostics

  stats
      Usage and cost savings report

  test [...]
      Run the end-to-end test suite

MAINTENANCE
  cleanup <data|images|kilo|claude|all> [--yes]
      Remove optional state selectively:
        data    cached pricing and stats (.data/)
        images  pulled Docker images
        kilo    Kilo client config
        claude  Claude Code client config
        all     everything above

INSTALL
  uninstall [--yes]
      Remove headway entirely: containers, images, data, client configs,
      shell completion, PATH symlink, and the headway directory

  secret-scan
      Run local secret scan

  completion [bash|zsh|fish|auto]
      Print shell completion script (auto-detects shell if omitted)
        eval "$(headway completion)"       # → auto-detected, add to rc file
        eval "$(headway completion bash)"  # → explicit bash
        headway completion fish > ~/.config/fish/completions/headway.fish

  help
      Show this message
EOF
}

main() {
  if [[ $# -lt 1 ]]; then
    print_help
    exit 1
  fi

  local cmd="$1"
  shift
  case "$cmd" in
    init)
      cmd_init "$@"
      ;;
    up)
      cmd_up "$@"
      ;;
    down)
      cmd_down "$@"
      ;;
    restart)
      cmd_restart "$@"
      ;;
    update)
      cmd_update "$@"
      ;;
    reset)
      cmd_reset "$@"
      ;;
    auth)
      cmd_auth "$@"
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    test)
      cmd_test "$@"
      ;;
    stats)
      cmd_stats "$@"
      ;;
    config)
      cmd_config "$@"
      ;;
    secret-scan)
      cmd_secret_scan "$@"
      ;;
    cleanup)
      cmd_cleanup "$@"
      ;;
    uninstall)
      cmd_uninstall "$@"
      ;;
    completion)
      cmd_completion "$@"
      ;;
    help | -h | --help)
      print_help
      ;;
    *)
      echo "Unknown command: $cmd"
      print_help
      exit 1
      ;;
  esac
}

main "$@"

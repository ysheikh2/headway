# Generated by ./headway init and ./headway up
# Never commit your local .env; this template is safe to share.
# Required: primary AWS profile used for LiteLLM lane and as fallback for Bedrock profiles.
AWS_PROFILE=default
# Optional: profile for native Bedrock runtime lane (:4002). Defaults to AWS_PROFILE when unset.
# BEDROCK_AWS_PROFILE=default
# Optional: profile for Bedrock model discovery during `./headway config regen`.
# Defaults to BEDROCK_AWS_PROFILE, then AWS_PROFILE when unset.
# BEDROCK_DISCOVERY_AWS_PROFILE=default
# Bedrock native lane region (must match model region for direct :4002 calls)
AWS_REGION=eu-central-1
# Optional override for Bedrock native lane image.
HEADROOM_BEDROCK_IMAGE=ghcr.io/ysheikh2/headway:bedrock-native

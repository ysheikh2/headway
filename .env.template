# Generated by ./headway init and ./headway up
# Never commit your local .env; this template is safe to share.
# Required: primary AWS profile used for LiteLLM lane and as fallback for Bedrock profiles.
AWS_PROFILE=default
# Bedrock runtime lane profile (:4002). Defaults to AWS_PROFILE — set to a different profile if needed.
BEDROCK_AWS_PROFILE=default
# Bedrock model discovery profile (used by `headway config regen`). Defaults to BEDROCK_AWS_PROFILE.
BEDROCK_DISCOVERY_AWS_PROFILE=default
# Bedrock native lane region (must match model region for direct :4002 calls)
AWS_REGION=eu-central-1
# Headroom image — runs both the Python proxy (:4000/:4002) and the native
# bedrock proxy (headroom-proxy). The upstream :code image bundles the native
# binary; the bedrock service overrides the entrypoint to headroom-proxy.
HEADROOM_IMAGE=ghcr.io/chopratejas/headroom:code
# Optional: tune Copilot/OpenAI lane compression. These are enabled defaults for
# Headway local usage and can be changed/removed per environment.
HEADROOM_COMPRESS_USER_MESSAGES=1
HEADROOM_MIN_TOKENS=120
HEADROOM_PROTECT_RECENT=2
# Optional: Bedrock native lane Anthropic cache marker auto-placement.
# Keep enabled to improve Bedrock prompt-cache hit behavior on repeated contexts.
HEADWAY_BEDROCK_AUTO_CACHE_CONTROL=1
# Optional: log raw Bedrock compression debug info (0 = off, 1 = on). Defaults to 0.
# HEADWAY_BEDROCK_DEBUG_COMPRESS=0

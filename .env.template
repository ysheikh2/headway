# Generated by ./headway init and ./headway up
# Never commit your local .env; this template is safe to share.
# Required: primary AWS profile used for the LiteLLM/Copilot lane and as the
# fallback for the Bedrock profiles.
AWS_PROFILE=default
# Bedrock lane profile (used by the native Rust proxy for SigV4 signing).
# Defaults to AWS_PROFILE — set to a different profile if needed.
BEDROCK_AWS_PROFILE=default
# Bedrock model discovery profile (used by `headway config regen`). Defaults to BEDROCK_AWS_PROFILE.
BEDROCK_DISCOVERY_AWS_PROFILE=default
# Bedrock lane region (must match the model region for direct calls).
AWS_REGION=eu-central-1
# Headroom image — the single native Rust `headroom-proxy` binary fronts every
# lane (Copilot/OpenAI via LiteLLM, Bedrock via native SigV4) and serves the
# unified /stats + /dashboard. The upstream :code image bundles the binary.
HEADROOM_IMAGE=ghcr.io/chopratejas/headroom:code
# Optional: named live-zone savings profile for the proxy (agent-friendly default).
HEADROOM_PROXY_SAVINGS_PROFILE=agent-90
